.container {
  padding: 20rpx;
}

.shop-header {
  display: flex;
  margin-bottom: 30rpx;
}

.shop-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.shop-info {
  flex: 1;
}

.shop-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.shop-intro {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.shop-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.shop-rating {
  font-size: 28rpx;
  color: #ff9900;
}

.rating-count {
  color: #999;
  margin-left: 10rpx;
}

.delivery-info {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
  font-size: 24rpx;
}

.rating-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.rating-stars {
  display: flex;
  gap: 20rpx;
}

.star {
  font-size: 50rpx;
  color: #ddd;
}

.star.active {
  color: #ff9900;
}

.platform-section {
  margin-bottom: 30rpx;
}

.platform-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.platform-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #3cc51f;
  color: #fff;
  border-radius: 10rpx;
}

.action-bar {
  margin-bottom: 30rpx;
}

.favorite-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border: 2rpx solid #3cc51f;
  color: #3cc51f;
  border-radius: 10rpx;
}

.favorite-btn.active {
  background: #3cc51f;
  color: #fff;
}

.disclaimer {
  padding: 20rpx;
  background: #fff3cd;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #856404;
  line-height: 1.6;
}
