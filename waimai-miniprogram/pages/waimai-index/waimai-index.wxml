<view class="container">
  <!-- 每日推荐 -->
  <view class="recommend-section">
    <view class="section-title">每日推荐</view>
    <scroll-view class="recommend-scroll" scroll-x>
      <view class="recommend-item" wx:for="{{dailyRecommend}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="recommend-image" src="{{item.coverUrl}}" mode="aspectFill"></image>
        <view class="recommend-name">{{item.name}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- 商家列表 -->
  <view class="shop-section">
    <view class="section-header">
      <view class="section-title">商家列表</view>
      <view class="more-link" bindtap="goToList">更多 ></view>
    </view>
    <view class="shop-list">
      <view class="shop-item" wx:for="{{shopList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="shop-image" src="{{item.coverUrl}}" mode="aspectFill"></image>
        <view class="shop-info">
          <view class="shop-name">{{item.name}}</view>
          <view class="shop-intro">{{item.introduction}}</view>
          <view class="shop-meta">
            <text class="category">{{item.categoryName}}</text>
            <text class="price" wx:if="{{item.startingPrice}}">起送¥{{item.startingPrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
