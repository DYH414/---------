<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商家" value="{{keyword}}" bindinput="onSearchInput" />
    <button class="search-btn" bindtap="handleSearch">搜索</button>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <!-- TODO: 实现平台和分类筛选 -->
  </view>

  <!-- 商家列表 -->
  <view class="shop-list">
    <view class="shop-item" wx:for="{{shopList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="shop-image" src="{{item.coverUrl}}" mode="aspectFill"></image>
      <view class="shop-info">
        <view class="shop-name">{{item.name}}</view>
        <view class="shop-intro">{{item.introduction}}</view>
        <view class="shop-meta">
          <text class="category">{{item.categoryName}}</text>
          <text class="price" wx:if="{{item.startingPrice}}">起送¥{{item.startingPrice}}</text>
        </view>
        <view class="shop-rating" wx:if="{{item.avgScore}}">
          <text>⭐ {{item.avgScore}}</text>
          <text class="rating-count">({{item.ratingCount}})</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="loading-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="no-more" wx:if="{{!hasMore && shopList.length > 0}}">
    <text>没有更多了</text>
  </view>
</view>
